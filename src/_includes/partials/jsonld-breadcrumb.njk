<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ ("nav.home" | i18n) | dump | safe }},
      "item": {{ (site.url + "/" + locale + "/") | dump | safe }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ ("nav.blog" | i18n) | dump | safe }},
      "item": {{ (site.url + "/" + locale + "/blog/") | dump | safe }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ title | dump | safe }},
      "item": {{ (site.url + page.url) | dump | safe }}
    }
  ]
}
</script>
