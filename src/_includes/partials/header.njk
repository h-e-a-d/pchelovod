<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/{{ locale }}/" class="brand" aria-label="{{ site.name }}">{{ site.name }}</a>
    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Open navigation"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav id="primary-nav" aria-label="Primary">
      <a href="/{{ locale }}/#home" class="nav-link">{{ "nav.home" | i18n }}</a>
      <a href="/{{ locale }}/#about" class="nav-link">{{ "nav.about" | i18n }}</a>
      <a href="/{{ locale }}/#honey" class="nav-link">{{ "nav.honey" | i18n }}</a>
      <a href="/{{ locale }}/#beehives" class="nav-link">{{ "nav.beehives" | i18n }}</a>
      <a href="/{{ locale }}/blog/" class="nav-link">{{ "nav.blog" | i18n }}</a>
      <a href="/{{ locale }}/#contact" class="nav-link">{{ "nav.contact" | i18n }}</a>
    </nav>
    {% include "partials/language-switcher.njk" %}
  </div>
</header>
