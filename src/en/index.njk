---
title: Pchelovod — Tajik Honey & Beehives
description: Raw honey and handmade beehives from the Pamir mountains of Tajikistan.
permalink: /en/
layout: layouts/landing.njk
---

{# ── Hero ──────────────────────────────────────────────────── #}
<section id="home" class="hero-section" aria-label="Home">
  <div class="hero-bg-blob" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-content">
      <p class="hero-origin">{{ "home.origin" | i18n }}</p>
      <h1 class="hero-headline">
        Honey from the<br />
        <em>Tajik</em> mountains
      </h1>
      <p class="hero-lead">{{ "home.heroLead" | i18n }}</p>
      <div class="hero-actions">
        <a href="#honey" class="btn btn-honey">{{ "home.ctaHoney" | i18n }}</a>
        <a href="/{{ locale }}/blog/" class="btn btn-outline">{{ "home.ctaBlog" | i18n }}</a>
      </div>
    </div>

