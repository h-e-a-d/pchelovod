  <div class="hero-scroll" aria-hidden="true">
    <div class="hero-scroll-line"></div>
  </div>
</section>

{# ── About ─────────────────────────────────────────────────── #}
<section id="about" class="about-section" aria-label="{{ 'about.label' | i18n }}">
  <div class="about-inner">
    <div class="about-stats">
      <div class="about-stat reveal">
        <div class="about-stat-value">{{ "about.stat1Value" | i18n }}</div>
        <div class="about-stat-label">{{ "about.stat1Label" | i18n }}</div>
      </div>
      <div class="about-stat reveal" data-delay="100">
        <div class="about-stat-value">{{ "about.stat2Value" | i18n }}</div>
        <div class="about-stat-label">{{ "about.stat2Label" | i18n }}</div>
      </div>
      <div class="about-stat reveal" data-delay="200">
        <div class="about-stat-value">{{ "about.stat3Value" | i18n }}</div>
        <div class="about-stat-label">{{ "about.stat3Label" | i18n }}</div>
      </div>
    </div>
    <div class="about-body">
      <div class="about-text reveal">
        <span class="section-label">{{ "about.label" | i18n }}</span>
        <h2>{{ "about.title" | i18n }}</h2>
        <p>{{ "about.body" | i18n }}</p>
      </div>
      <div class="about-image-wrap reveal" data-delay="200">
        {% image "/assets/images/pamir-apiary.jpg", "Wooden beehives on an alpine meadow in the Pamir mountains", "(min-width: 900px) 40vw, 90vw", "lazy" %}
      </div>
    </div>
  </div>
</section>

{# ── Honey ─────────────────────────────────────────────────── #}
<section id="honey" class="honey-section" aria-label="{{ 'honey.label' | i18n }}">
  <div class="honey-inner">
    <div class="honey-header reveal">
      <span class="section-label">{{ "honey.label" | i18n }}</span>
      <h2>{{ "honey.title" | i18n }}</h2>
      <p>{{ "honey.lead" | i18n }}</p>
    </div>
    <div class="honey-grid">
      <div class="honey-card reveal">
        <div class="honey-card-num" aria-hidden="true">01</div>
        <h3>{{ "honey.v1name" | i18n }}</h3>
        <p>{{ "honey.v1desc" | i18n }}</p>
      </div>
      <div class="honey-card reveal" data-delay="150">
        <div class="honey-card-num" aria-hidden="true">02</div>
        <h3>{{ "honey.v2name" | i18n }}</h3>
        <p>{{ "honey.v2desc" | i18n }}</p>
      </div>
      <div class="honey-card reveal" data-delay="300">
        <div class="honey-card-num" aria-hidden="true">03</div>
        <h3>{{ "honey.v3name" | i18n }}</h3>
        <p>{{ "honey.v3desc" | i18n }}</p>
      </div>
    </div>
  </div>
</section>

{# ── Beehives ──────────────────────────────────────────────── #}
<section id="beehives" class="beehives-section" aria-label="{{ 'beehives.label' | i18n }}">
  <div class="beehives-inner">
    <div class="beehives-text reveal">
      <span class="section-label">{{ "beehives.label" | i18n }}</span>
      <h2>{{ "beehives.title" | i18n }}</h2>
      <p>{{ "beehives.body" | i18n }}</p>
      <ul class="beehives-details">
        <li>{{ "beehives.detail1" | i18n }}</li>
        <li>{{ "beehives.detail2" | i18n }}</li>
        <li>{{ "beehives.detail3" | i18n }}</li>
      </ul>
    </div>
    <div class="beehives-visual reveal" data-delay="200">
      <div class="beehives-image-wrap">
        {% image "/assets/images/pamir-apiary.jpg", "Handcrafted wooden beehive in the Tajik mountains", "(min-width: 900px) 40vw, 90vw", "lazy" %}
      </div>
      <div class="beehives-badge" aria-hidden="true">
        <span class="beehives-badge-num">3</span>
        <span class="beehives-badge-label">Generations</span>
      </div>
    </div>
  </div>
</section>

{# ── Contact ───────────────────────────────────────────────── #}
<section id="contact" class="contact-section" aria-label="{{ 'contact.label' | i18n }}">
  <div class="contact-inner">
    <div class="contact-info reveal">
      <span class="section-label">{{ "contact.label" | i18n }}</span>
      <h2>{{ "contact.title" | i18n }}</h2>
      <p>{{ "contact.lead" | i18n }}</p>
      <div class="contact-links">
        <a href="mailto:{{ site.contactEmail }}" class="contact-link">
          <span class="contact-link-icon" aria-hidden="true">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
          </span>
          <span>{{ "contact.emailLabel" | i18n }} — {{ site.contactEmail }}</span>
        </a>
        <a href="https://t.me/pchelovod" class="contact-link" rel="noopener">
          <span class="contact-link-icon" aria-hidden="true">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 5 2 12.5l7 1M21 5l-2.5 15L9 13.5M21 5 9 13.5m0 0 1 5.5 3-3" />
            </svg>
          </span>
          <span>{{ "contact.telegram" | i18n }}</span>
        </a>
        <a href="https://wa.me/992900000000" class="contact-link" rel="noopener">
          <span class="contact-link-icon" aria-hidden="true">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
              />
            </svg>
          </span>
          <span>{{ "contact.whatsapp" | i18n }}</span>
        </a>
      </div>
    </div>

    <div class="contact-form-wrap reveal" data-delay="200">
      <div
        id="form-status"
        data-success="{{ 'form.success' | i18n }}"
        data-error="{{ 'form.error' | i18n }}"
        aria-live="polite"
        style="margin-bottom:1rem;font-size:0.9rem;color:var(--color-honey-200);min-height:1.5rem;"
      ></div>
      {% include "partials/contact-form.njk" %}
    </div>
  </div>
</section>
