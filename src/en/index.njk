      />
      <polygon
        points="179.9,75 223.2,100 223.2,150 179.9,175 136.6,150 136.6,100"
        fill="none"
        stroke="currentColor"
        stroke-width="1.25"
      />
      <polygon
        points="266.5,75 309.8,100 309.8,150 266.5,175 223.2,150 223.2,100"
        fill="none"
        stroke="currentColor"
        stroke-width="1.25"
      />
      <polygon
        points="353.1,75 396.4,100 396.4,150 353.1,175 309.8,150 309.8,100"
        fill="none"
        stroke="currentColor"
        stroke-width="1.25"
      />
      <polygon
        points="50,150 93.3,175 93.3,225 50,250 6.7,225 6.7,175"
        fill="none"
        stroke="currentColor"
        stroke-width="1.25"
      />
