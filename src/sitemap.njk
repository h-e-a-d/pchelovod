---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---

<?xml version="1.0" encoding="utf-8"?>
<urlset
  xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml"
>
  {% for item in collections.all %}
    {% if not item.data.eleventyExcludeFromCollections %}
      <url>
        <loc>{{ site.url }}{{ item.url }}</loc>
        <lastmod>{{ item.date | dateToRfc3339 }}</lastmod>
        {% if item.data.locale %}
          <xhtml:link
            rel="alternate"
            hreflang="{{ item.data.locale }}"
            href="{{ site.url }}{{ item.url }}"
          />
          {% for link in item.url | locale_links %}
            <xhtml:link
              rel="alternate"
              hreflang="{{ link.lang }}"
              href="{{ site.url }}{{ link.url }}"
            />
          {% endfor %}
          {% if item.data.locale == 'en' %}
            <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ item.url }}" />
          {% else %}
            {% for link in item.url | locale_links %}
              {% if link.lang == 'en' %}
                <xhtml:link
                  rel="alternate"
                  hreflang="x-default"
                  href="{{ site.url }}{{ link.url }}"
                />
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endif %}
      </url>
    {% endif %}
  {% endfor %}
</urlset>
